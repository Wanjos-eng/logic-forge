{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "logic-forge",
  "version": "0.1.0",
  "identifier": "com.wanjos.logic-forge",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "logic-forge",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "appimage"],
    "shortDescription": "Editor e analisador de lógica proposicional",
    "longDescription": "Logic Forge é um editor visual para fórmulas lógicas, com análise semântica, árvore sintática e tabela verdade.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "allowDowngrades": false,
      "nsis": {
        "compression": "lzma",
        "displayLanguageSelector": true,
        "installMode": "currentUser",
        "startMenuFolder": "Logic Forge"
      },
      "webviewInstallMode": {
        "silent": true,
        "type": "downloadBootstrapper"
      }
    }
  }
}
